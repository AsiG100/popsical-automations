# Example environment variables for local development
# Copy this file to `.env` and fill in the values.

# Django
DJANGO_SECRET_KEY=changeme
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth credentials (create these in Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Eventbrite
# Get your private token from: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_TOKEN=

# Mailchimp
# API key: Mailchimp → Account → Extras → API Keys
MAILCHIMP_API_KEY=
# Audience ID: Mailchimp → Audience → Settings → Audience name & defaults
MAILCHIMP_LIST_ID=
